{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["project_name", "app_root", "build_command", "output_dir", "branch", "pages_alias", "required_env"],
  "additionalProperties": false,
  "properties": {
    "project_name": {"type": "string"},
    "app_root": {"type": "string"},
    "build_command": {"type": "string"},
    "output_dir": {"type": "string"},
    "branch": {"type": "string"},
    "pages_alias": {"type": "string"},
    "custom_domains": {"type": "array", "items": {"type": "string"}},
    "required_env": {"type": "array", "items": {"type": "string"}},
    "pre_deploy": {
      "type": "object", "required": ["command"], "additionalProperties": false,
      "properties": {"command": {"type": "string"}, "description": {"type": "string"}}
    },
    "post_deploy_smoke": {"type": "string"},
    "pages_limits": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "max_files": {"type": "integer", "default": 20000},
        "max_file_size_mb": {"type": "number", "default": 25},
        "max_build_size_mb": {"type": "number", "default": 25}
      }
    }
  }
}
