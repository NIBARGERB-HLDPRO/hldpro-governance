{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hldpro.local/schemas/cli-session-event.schema.json",
  "title": "Governed CLI Session Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_event_id",
    "tool",
    "role",
    "model",
    "reasoning_effort",
    "cwd",
    "command_argv",
    "prompt_path",
    "prompt_sha256",
    "stdout_path",
    "stderr_path",
    "started_at",
    "last_output_at",
    "ended_at",
    "pid",
    "pgid",
    "exit_code",
    "termination_reason",
    "wall_timeout_sec",
    "silence_timeout_sec",
    "retry_of",
    "retry_count",
    "scope_slug",
    "scope_reduction_summary",
    "handoff_package_ref"
  ],
  "properties": {
    "schema_version": { "const": "v1" },
    "session_event_id": {
      "type": "string",
      "pattern": "^cli_[0-9]{8}T[0-9]{6}Z_[a-f0-9]{12}$"
    },
    "tool": { "enum": ["claude", "codex"] },
    "role": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "reasoning_effort": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "cwd": { "type": "string", "minLength": 1 },
    "command_argv": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "prompt_path": { "type": "string", "minLength": 1 },
    "prompt_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stdout_path": { "type": "string", "minLength": 1 },
    "stderr_path": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "last_output_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "ended_at": { "type": "string", "format": "date-time" },
    "pid": { "type": ["integer", "null"], "minimum": 1 },
    "pgid": { "type": ["integer", "null"], "minimum": 1 },
    "exit_code": { "type": ["integer", "null"] },
    "termination_reason": {
      "enum": [
        "succeeded",
        "failed_nonzero",
        "idle_timeout",
        "total_timeout",
        "terminated",
        "abandoned"
      ]
    },
    "wall_timeout_sec": { "type": "number", "exclusiveMinimum": 0 },
    "silence_timeout_sec": { "type": "number", "exclusiveMinimum": 0 },
    "retry_of": {
      "type": ["string", "null"],
      "pattern": "^cli_[0-9]{8}T[0-9]{6}Z_[a-f0-9]{12}$"
    },
    "retry_count": { "type": "integer", "minimum": 0 },
    "scope_slug": { "type": "string", "minLength": 1 },
    "scope_reduction_summary": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "handoff_package_ref": {
      "type": ["string", "null"],
      "minLength": 1
    }
  }
}
