{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO_ROOT=$(git -C \"${CLAUDE_CWD:-$PWD}\" rev-parse --show-toplevel 2>/dev/null) && bash \"$REPO_ROOT/hooks/pre-session-context.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/Developer/HLDPRO/hldpro-governance/hooks/schema-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/Developer/HLDPRO/hldpro-governance/hooks/code-write-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/Developer/HLDPRO/hldpro-governance/hooks/check-errors.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
