{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo $PWD)/hooks/pre-session-context.sh\"'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo $PWD)/hooks/schema-guard.sh\"'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo $PWD)/hooks/code-write-gate.sh\"'",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
