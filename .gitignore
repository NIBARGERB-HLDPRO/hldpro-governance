# Ephemeral / large
history.jsonl
sessions/
cache/
paste-cache/
file-history/
session-env/
plans/
!docs/plans/
!docs/plans/*.json
!docs/plans/*.md
downloads/
backups/

# Sensitive
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Per-project memory (conversation-specific, managed by auto-memory)
projects/

# Plugins (installed separately)
plugins/

# Misc ephemeral
__pycache__/
**/__pycache__/
*.py[cod]
shell-snapshots/
stats-cache.json
tasks/
image-cache/

# graphify artifact contract:
# canonical artifacts are committed under graphify-out/<repo>/, including nested .graphify_*.json
# local runtime noise stays ignored here and through repo-wide cache/.DS_Store rules
graphify-out/graph.html
graphify-out/cache/
graphify-out/.graphify_tmp.json

# raw/ large media files (append-only text files are tracked)
raw/**/*.mp3
raw/**/*.wav

# Claude Code local tooling state (worktrees, local settings)
.claude/
!.claude/settings.json
!.claude/hooks/

# OS
.DS_Store

# Operator secret vault — NEVER COMMIT
.env
.env.shared
.env.local
.env.*.local
